---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="AI项目 / AI Projects">
  <div class="site-container mx-auto h-[70vh] flex items-center justify-center">
    <div class="flex flex-col items-center justify-center py-32 text-center">
      <h2
        class="text-xl sm:text-2xl font-bold text-neutral-500 dark:text-neutral-400 mb-3"
        style="font-family: 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;"
        data-aos="fade-up-sm"
        data-aos-duration="600"
        data-aos-once="true"
        data-i18n="about-title"
      >
        正在更新...
      </h2>
      <p
        class="text-neutral-400 dark:text-neutral-500 text-sm"
        style="font-family: 'PingFang SC', 'Microsoft YaHei', 'Noto Sans SC', sans-serif;"
        data-aos="fade-up-sm"
        data-aos-delay="100"
        data-aos-duration="600"
        data-aos-once="true"
        data-i18n="about-desc"
      >
        AI 项目页面正在建设中，敬请期待
      </p>
    </div>
  </div>
</Layout>
